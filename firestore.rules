rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if true;
      allow write: if false;
    }
    match /collections/{collectionId} {
      allow read: if true;
      allow write: if false;
    }
    match /articles/{articleId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
