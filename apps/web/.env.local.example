# Firebase Configuration
# Firebase Console > Project Settings > General > Your apps で取得
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=curation-persona.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=curation-persona
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=curation-persona.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Emulator 接続（ローカル開発時は true）
NEXT_PUBLIC_USE_EMULATOR=true
